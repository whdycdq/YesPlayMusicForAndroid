{
  "appId": "com.yesplaymusic.android",
  "appName": "YesPlayMusic",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#ffffff"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SystemBars": {
      "insetsHandling": "disable",
      "style": "LIGHT"
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "LIGHT",
      "backgroundColor": "#FFFFFF"
    }
  }
}
